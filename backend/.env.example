# Required: AMap Web Service API key for POI retrieval and route APIs.
AMAP_API_KEY=your_amap_web_service_key
MAP_PROVIDER=amap

# Required: OpenAI or OpenAI-compatible model configuration.
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional aliases supported by the runtime.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_ID=

# Optional image lookup.
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# Weather defaults to Open-Meteo and does not require a key.
WEATHER_PROVIDER=openmeteo
OPENWEATHER_API_KEY=

# Application configuration.
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
