# Intelligent Trip Planner frontend environment template.
# Copy this file to `.env` for local development.

# FastAPI backend base URL.
VITE_API_BASE_URL=http://localhost:8000

# Google Maps JavaScript API key for browser map rendering.
# Restrict this key by HTTP referrer in Google Cloud.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_javascript_api_key_here
