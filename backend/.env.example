# Intelligent Trip Planner backend environment template.
# Copy this file to `.env` for local development and replace placeholder values.
# Do not commit real API keys.

# Required for active runtime: Google Maps Platform API key.
# Enable Places API (New), Geocoding API, Routes API, and Maps JavaScript API
# in the same Google Cloud project. The backend uses Places, Geocoding, and Routes.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
MAP_PROVIDER=google

# Required for LangChain planner and OpenAI embeddings.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional OpenAI-compatible aliases supported by the runtime.
# If set, these override OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_ID=

# Optional specialist overrides. Empty values reuse the shared model above.
EXPERIENCE_MODEL=
LOGISTICS_MODEL=
COMPOSER_MODEL=

# Optional image lookup for destination photos.
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# Weather defaults to Open-Meteo and does not require a key.
WEATHER_PROVIDER=openmeteo
OPENWEATHER_API_KEY=

# Retrieval mode for planner context.
# Use chroma_retrieval for the real Chroma + OpenAI embeddings pipeline.
# Use local_lightweight for cheap baseline/debug runs.
RAG_MODE=chroma_retrieval

# Optional route-time-aware route coherence evaluation.
# Disabled by default; when enabled, LangGraph precomputes bounded same-day
# attraction transfer estimates through the configured map provider before
# deterministic evaluation.
ROUTE_TIME_EVALUATION_ENABLED=false
MAX_ROUTE_TIME_EVALUATIONS_PER_TRIP=12
MAX_SEGMENT_MINUTES_BY_MODE={"walking":30,"transit":45,"driving":35,"bicycling":30}
MAX_DAILY_TRANSIT_MINUTES_BY_MODE={"walking":90,"transit":150,"driving":120,"bicycling":120}

# Application configuration.
APP_ENV=local
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Optional lightweight protection for local-admin routes.
# In production APP_ENV=production requires this token for admin endpoints.
# Send it as the X-Admin-Token header.
ADMIN_API_TOKEN=

# Local generated files are configured in code and should not be committed:
# - data/index/chroma/
# - data/memory/*.sqlite3
# - data/observability/*.sqlite3
#
# Deprecated note:
# AMAP_API_KEY is no longer used by the active runtime after the Google Maps refactor.
